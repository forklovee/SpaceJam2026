[sub_resource type="Shader" id="Shader_0xm2m"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx, unshaded;

uniform vec4 albedo : source_color;
uniform float scale=100.0;
uniform vec2 stars[40];
uniform vec3 stars_color[40];
uniform int stars_ani[40];
void vertex() {
}

void fragment() {
	vec2 pos = (UV-vec2(0.5,0.5))*scale*2.0;
	ALBEDO = albedo.rgb;
	float far_l=0.0;
	for(int id=0;id<40;id++){
		vec2 star=stars[id];
		float dist=length(pos-star);
		if(dist<3.0){
			if (stars_ani[id]==0){
				float l=(3.0-dist)/3.0;
				float f=(0.8+0.2*sin(TIME+l*10.0));
				ALBEDO += l*stars_color[id]*f;
				
			}
			else{
				float l=(3.0-dist)/3.0;
				float f=(0.5+0.5*sin(TIME+l*10.0))*(0.5+0.5*sin(TIME*0.4));
				ALBEDO += l*stars_color[id]*f*f*2.0;
			}
			
		}
		far_l+=1.0/(1.0+dist*dist);
	}
	ALBEDO += vec3(1.0+0.1*sin(pos.x),1.0+0.1*sin(pos.y),1.0)*min(far_l,0.1)*1.3;
	
}
"

